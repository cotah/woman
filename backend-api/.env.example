# ============================================================
# SafeCircle Backend Configuration
# ============================================================

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=safecircle
DB_PASSWORD=safecircle_dev
DB_DATABASE=safecircle

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_REFRESH_EXPIRATION=7d

# S3 Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_AUDIO=safecircle-audio
S3_BUCKET_EVIDENCE=safecircle-evidence

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
TWILIO_VOICE_URL=

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# Deepgram (Speech-to-text)
DEEPGRAM_API_KEY=

# OpenAI (AI analysis)
OPENAI_API_KEY=

# Mapbox (for backend geocoding if needed)
MAPBOX_ACCESS_TOKEN=

# Encryption
ENCRYPTION_KEY=change-this-32-byte-hex-string

# Feature Flags
FEATURE_WEARABLE_TRIGGERS=false
FEATURE_DISGUISED_UI=false
FEATURE_AI_RISK_ENGINE=false
FEATURE_GEOFENCING=false
FEATURE_ORG_MODE=false
FEATURE_VOICE_CALLS=true
FEATURE_AUDIO_ANALYSIS=true

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
